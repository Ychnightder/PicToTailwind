{
	"name": "backend",
	"version": "1.0.0",
	"description": "This project was bootstrapped with Fastify-CLI.",
	"main": "app.ts",
	"type": "module",
	"directories": {
		"test": "test"
	},
	"scripts": {
		"test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
		"start": "npm run build:ts && fastify start -l info dist/app.js -p 5000",
		"build:ts": "tsc",
		"watch:ts": "tsc -w",
		"dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
		"dev:start": "fastify start --ignore-watch=.ts$ -w -l info dist/app.js -p 5000"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@fastify/autoload": "^6.0.0",
		"@fastify/cors": "^11.2.0",
		"@fastify/multipart": "^10.0.0",
		"@fastify/sensible": "^6.0.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"dotenv": "^17.4.2",
		"fastify": "^5.8.5",
		"fastify-cli": "^8.0.0",
		"fastify-plugin": "^5.1.0",
		"firebase-admin": "^13.10.0",
		"groq-sdk": "^1.2.1",
		"pg": "^8.21.0",
		"pixelmatch": "^7.2.0",
		"pngjs": "^7.0.0",
		"puppeteer": "^25.1.0",
		"quantize": "^1.0.2",
		"sharp": "^0.34.5",
		"tesseract.js": "^7.0.0"
	},
	"devDependencies": {
		"@types/multer": "^2.1.0",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"@types/pixelmatch": "^5.2.6",
		"@types/pngjs": "^6.0.5",
		"c8": "^11.0.0",
		"concurrently": "^9.0.0",
		"fastify-tsconfig": "^3.0.0",
		"ts-node": "^10.4.0",
		"tsx": "^4.22.3",
		"typescript": "~5.9.2"
	},
	"overrides": {
		"@hono/node-server": "^1.19.13",
		"uuid": "^11.1.1"
	}
}
