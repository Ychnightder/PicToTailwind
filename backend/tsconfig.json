{
	"extends": "fastify-tsconfig",
	"compilerOptions": {
		"outDir": "dist",
		"sourceMap": true,
		"rootDir": "src",
		"target": "ES2023",
		"strict": true,
		"esModuleInterop": true,
		"module": "NodeNext",           // <-- Gère l'ESM natif de Node de façon stricte
    	"moduleResolution": "NodeNext",
	},
	"include": ["src/**/*.ts"]
}
