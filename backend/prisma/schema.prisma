generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}




model Conversion {
  id        String   @id @default(uuid()) // Génère un identifiant unique automatique pour la conversion
  htmlCode  String   // Le code HTML/Tailwind généré de manière éphémère par Groq
  createdAt DateTime @default(now())
}