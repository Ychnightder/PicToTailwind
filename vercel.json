{
	"experimentalServices": {
		"frontend": {
			"root": "frontend",
			"routePrefix": "/",
			"framework": "nextjs"
		},
		"backend": {
			"root": "backend",
			"routePrefix": "/_/backend",
            "rewrites": [
                { "source": "/api/(.*)", "destination": "/api/index.ts" }
            ]
		}
	}
}
